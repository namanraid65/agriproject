PORT=5000
# Replace with your own Atlas URI — never commit real credentials
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/open-agri?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
NODE_ENV=development
CLIENT_URL=http://localhost:3000,http://localhost:5173
